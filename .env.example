# Runtime
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_TIME_ZONE=Europe/Vilnius
DJANGO_DB_URL=postgres://postgres@db:5432/postgres
DJANGO_ALLOWED_HOSTS=*
DEBUG=True

# Optional in local Vite dev mode
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Bootstrap admin user
SUPERUSER_NAME=admin
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=admin

# Auth mode: local | oauth
AUTH_MODE=local

# OAuth / OIDC settings (used only when AUTH_MODE=oauth)
OAUTH_ISSUER_URL=https://sso.example.com/realms/Example
OAUTH_CLIENT_ID=cli.example.com
OAUTH_CLIENT_SECRET=
OAUTH_SCOPES=openid profile email
OAUTH_SIGN_ALGO=RS256
OAUTH_VERIFY_SSL=True

# QA Postgres container
POSTGRES_HOST_AUTH_METHOD=trust
